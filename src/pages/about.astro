---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutIsland from '../components/react/about/island';
---

<BaseLayout title="damon | about" description="about me" ogImage="/about.png">
  <main class="max-w-3xl mx-auto py-12 px-8 pb-20 animate-fade-in space-y-8 text-base leading-relaxed">
    <h1 class="text-2xl font-light tracking-tight">about</h1>

    <div class="space-y-4 text-muted-foreground">
      <AboutIsland client:load />
    </div>

    <p class="text-muted-foreground text-base">
      sometimes I{' '}
      <a href="https://www.alltrails.com/members/damon-montague" target="_blank" rel="noopener noreferrer">hike</a>,{' '}
      take <a href="https://instagram.com/adopted" target="_blank" rel="noopener noreferrer">pictures</a>,{' '}
      and <a href="https://github.com/day-mon" target="_blank" rel="noopener noreferrer">code</a>.
    </p>
  </main>
</BaseLayout>

---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import xSvg from '../assets/icons/x.svg?raw';
import githubSvg from '../assets/icons/github.svg?raw';
import linkedinSvg from '../assets/icons/linkedin.svg?raw';
import discordSvg from '../assets/icons/discord.svg?raw';
import instagramSvg from '../assets/icons/instagram.svg?raw';
import musicSvg from '../assets/icons/music.svg?raw';
import mailSvg from '../assets/icons/mail.svg?raw';

const links = [
  { label: 'twitter',   href: 'https://twitter.com/lisp',                              svg: xSvg },
  { label: 'github',    href: 'https://github.com/day-mon',                              svg: githubSvg },
  { label: 'linkedin',  href: 'https://www.linkedin.com/in/day-mon/',                    svg: linkedinSvg },
  { label: 'discord',   href: 'https://discord.com/users/105141507996061696',           svg: discordSvg },
  { label: 'instagram', href: 'https://instagram.com/adopted',                           svg: instagramSvg },
  { label: 'music',     href: 'https://music.youtube.com/channel/UCVzQffzdvb43n-Vvw7grtqQ', svg: musicSvg },
];
---

<BaseLayout title="damon | contact" description="contact me" ogImage="/contact.png">
  <main class="max-w-3xl mx-auto py-12 px-8 pb-20 animate-fade-in space-y-8">
    <h1 class="text-2xl font-light tracking-tight">contact</h1>

    <div class="space-y-3">
      {links.map(({ label, href, svg }) => (
        <div class="flex items-center gap-2">
          <span class="size-4 shrink-0 text-muted-foreground [&>svg]:size-full" set:html={svg} />
          <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>
        </div>
      ))}

      <div class="flex items-center gap-2">
        <span class="size-4 shrink-0 text-muted-foreground [&>svg]:size-full" set:html={mailSvg} />
        <a href="mailto:damon@montague.im">damon@montague.im</a>
      </div>
    </div>
  </main>
</BaseLayout>
